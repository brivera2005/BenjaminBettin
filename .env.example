# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Random 32+ character secret for signing session cookies
AUTH_SECRET=generate-a-long-random-string-here

# App URL — must match Google OAuth redirect URI origin
# Local dev: http://localhost:8787 (preview) or http://localhost:3000 (next dev)
# Production: https://your-domain.pages.dev
APP_URL=http://localhost:8787
